# =============================================================================
# Yassir — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your keys.

# Required - LLM provider + HalalTerminal API
OPENAI_API_KEY=sk-proj-...

# Required - Get your free key at https://api.halalterminal.com
HALAL_TERMINAL_API_KEY=ht_...

# Web UI access code (required for hosted, optional for local dev)
# YASSIR_ACCESS_CODE=change-me-min-12-chars

# --- Additional LLM Providers (optional) ---
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# XAI_API_KEY=...
# DEEPSEEK_API_KEY=...
# OPENROUTER_API_KEY=...
# MOONSHOT_API_KEY=...
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- Search Providers (optional, improves web_search) ---
# EXASEARCH_API_KEY=...
# TAVILY_API_KEY=tvly-...
# PERPLEXITY_API_KEY=...

# --- X/Twitter Research (optional) ---
# X_BEARER_TOKEN=...

# --- Agent Tuning (optional) ---
# YASSIR_DEFAULT_MODEL=gpt-5.5
# YASSIR_DEFAULT_PROVIDER=openai
# YASSIR_MAX_ITERATIONS=10
